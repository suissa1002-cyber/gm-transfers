# ── NewOrder POS (read-only) ──
NEWORDER_API_TOKEN=
NEWORDER_BASE_URL=https://neworderapi.azurewebsites.net
NEWORDER_STORE_GUID=

# ── DB ──
# בפיתוח: השאר ריק → SQLite מקומי (transfers.db).
# ב-Render: internal Postgres connection string.
DATABASE_URL=

# ── Poller ──
POLL_INTERVAL_SEC=30
POLL_LOOKBACK_DAYS=3

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGERS_CHAT_ID=448181407
# JSON: מיפוי branchId -> chat_id של הסניף (אופציונלי)
TELEGRAM_BRANCH_CHATS=

# ── SLA ──
RECEIVE_REMINDER_HOURS=3
RECEIVE_ESCALATE_HOURS=24

# ── הגנת קונסולת הניהול (סניף "אתר") ──
# אם ריק → הניהול פתוח (פיתוח בלבד). בפרודקשן חובה להגדיר.
ADMIN_PASSWORD=

TZ=Asia/Jerusalem
