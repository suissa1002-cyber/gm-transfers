# uri-bridge — Render background worker (24/7 Uri brain) built FROM the gm-transfers repo
# (already connected to Render). Node 20 = Claude Code CLI; Python = the poller.
# Auth via CLAUDE_CODE_OAUTH_TOKEN (Max plan) at runtime.
# Runs as a NON-root user — claude refuses --dangerously-skip-permissions as root.
FROM node:20-bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 python3-pip ca-certificates git && rm -rf /var/lib/apt/lists/*
RUN npm install -g @anthropic-ai/claude-code
RUN pip3 install --break-system-packages --no-cache-dir requests>=2.31.0
RUN useradd -m -u 10001 uri
WORKDIR /app
COPY --chown=uri:uri . .
USER uri
ENV HOME=/home/uri
ENV PYTHONUNBUFFERED=1
CMD ["python3", "uri_bridge.py"]
